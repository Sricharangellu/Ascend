# Copy to .env.local and customise for your environment.
# NEVER commit .env.local to git.

# Backend API URL (Next.js rewrites /api/v1/* to this origin)
BACKEND_URL=http://localhost:3001

# Base URL for the API client (browser-side)
# Defaults to /api/v1 — change only if you're running the SPA standalone
# NEXT_PUBLIC_API_BASE_URL=/api/v1

# Force MSW mocks on in production for demo purposes (not for real prod!)
# NEXT_PUBLIC_MOCK=true
